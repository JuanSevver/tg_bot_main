# ───────────────────────────────────────────
# Скопируй этот файл в .env и заполни значения
#   cp .env.example .env
# ───────────────────────────────────────────

# Токен Telegram-бота (от @BotFather)
BOT_TOKEN=

# ID администраторов через запятую, например: 123456789,987654321
ADMIN_IDS=

# Username аккаунта поддержки (без @)
SUPPORT_USERNAME=

# Токен CryptoBot (от @CryptoBot)
CRYPTOBOT_TOKEN=

# Telegram API credentials (https://my.telegram.org/apps)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# DATABASE_URL задаётся автоматически в docker-compose.yml.
# Раскомментируй только если запускаешь без Docker:
# DATABASE_URL=sqlite+aiosqlite:///bot.db
